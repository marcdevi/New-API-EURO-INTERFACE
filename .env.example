# ============================================
# EURODESIGN PRO - CONFIGURATION
# ============================================
# SECURITY: Never commit this file with real values!
# Copy this file to .env.local and fill with your values
# ============================================

# Environment (development | production)
NODE_ENV=development

# Public URL of the application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# SUPABASE - REGENERATE KEYS AFTER COMPROMISE
# ============================================
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anonymous key (public) - can be exposed client-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Service role key (SECRET) - NEVER EXPOSE CLIENT-SIDE
# Regenerate via: Supabase Dashboard > Settings > API > Service Role Key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================
# SHOPIFY TOKEN ENCRYPTION
# ============================================
# Generate with: openssl rand -hex 32
SHOPIFY_TOKEN_ENCRYPTION_KEY=your_32_byte_hex_key

# ============================================
# REDIS / UPSTASH (Rate Limiting & Queue)
# ============================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# For BullMQ worker (optional, if using local Redis)
REDIS_URL=redis://localhost:6379

# ============================================
# ALLOWED ORIGINS (CORS)
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,https://eurodesignfrancepro.fr

# ============================================
# SHOPIFY OAUTH INTERFACE (Agent 2 + Agent 3)
# ============================================
# Backend API base URL — NEVER prefix with NEXT_PUBLIC_
# Use host.docker.internal when running in Docker to access host machine
# Example: http://host.docker.internal:3002 (Docker) or http://localhost:3002 (local dev)
API_BASE_URL=http://host.docker.internal:3002

# Secret key for authenticating with the backend API (Agent 2)
# Generate with: node -e "console.log('sk_prod_' + require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY=sk_prod_...

# Default shop domain (optional, for mono-tenant setups)
DEFAULT_SHOP_DOMAIN=ma-boutique.myshopify.com

# ============================================
# LOGGING & MONITORING (Optional)
# ============================================
# SENTRY_DSN=https://your-sentry-dsn

# ============================================
# POST-COMPROMISE INSTRUCTIONS
# ============================================
# 1. Regenerate ALL Supabase keys
# 2. Change ALL passwords (DB, SSH, etc.)
# 3. Regenerate SHOPIFY_TOKEN_ENCRYPTION_KEY
# 4. Regenerate Upstash tokens
# 5. Check authorized SSH keys on server
# 6. Reinstall server from clean image
